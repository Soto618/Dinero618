// service-worker.js - Versión corregida para GitHub Pages
const CACHE_NAME = 'presupuesto-pwa-v2';
const urlsToCache = [
  './',                     // ruta relativa a la raíz del sitio
  './index.html',
  './style.css',
  './app.js',
  './manifest.json',
  './icon-192.png',
  './icon-512.png'
];

self.addEventListener('install', event => {
  console.log('Service Worker instalado');
  event.waitUntil(
    caches.open(CACHE_NAME)
      .then(cache => {
        console.log('Archivos cacheados correctamente');
        return cache.addAll(urlsToCache);
      })
      .catch(err => console.error('Error al cachear:', err))
  );
  self.skipWaiting(); // Activar inmediatamente
});

self.addEventListener('fetch', event => {
  event.respondWith(
    caches.match(event.request)
      .then(response => {
        if (response) {
          return response; // Devuelve desde caché si existe
        }
        return fetch(event.request).then(fetchResponse => {
          // Opcional: cachear nuevas peticiones (solo GET y recursos estáticos)
          if (event.request.method === 'GET' && event.request.url.includes(location.origin)) {
            const responseToCache = fetchResponse.clone();
            caches.open(CACHE_NAME).then(cache => {
              cache.put(event.request, responseToCache);
            });
          }
          return fetchResponse;
        });
      })
      .catch(() => {
        // Fallback en caso de offline (puedes mostrar una página personalizada)
        return caches.match('./index.html');
      })
  );
});

self.addEventListener('activate', event => {
  console.log('Service Worker activado');
  event.waitUntil(
    caches.keys().then(keys => {
      return Promise.all(
        keys.map(key => {
          if (key !== CACHE_NAME) {
            console.log('Eliminando caché antigua:', key);
            return caches.delete(key);
          }
        })
      );
    })
  );
  self.clients.claim(); // Tomar control inmediato de las páginas abiertas
});